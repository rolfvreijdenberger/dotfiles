# personal bin on PATH
[[ -d "$HOME/bin" ]] && export PATH="$HOME/bin:$PATH"

# bash completions (distro-agnostic)
if ! shopt -oq posix; then
  if [[ -f /usr/share/bash-completion/bash_completion ]]; then
    . /usr/share/bash-completion/bash_completion
  elif [[ -f /etc/bash_completion ]]; then
    . /etc/bash_completion
  fi
fi

# disable Ctrl+S terminal freeze (XON/XOFF flow control)
[[ -t 0 ]] && stty -ixon

# use vim for everything
export VISUAL=vim
export EDITOR=vim
# vi mode after completions to avoid interference
set -o vi


# bash shell prompt
# http://bashrcgenerator.com/
_generate_ps1() {
  last_status="$?"
  local _bold='\[\e[1m\]' _nc='\[\e[0m\]'
  local _theme; _theme=$(cat ~/.theme-bash-tmux-vim 2>/dev/null) || _theme=dark
  if [[ "$_theme" == "light" ]]; then
    local _hi='\[\033[0;34m\]'  # blue         — user, host
    local _lo='\[\033[0;31m\]'  # red          — @, git, $
    local _di='\[\033[0;35m\]'  # magenta — dir
    local _ok='\[\033[0;32m\]'  # green        — exit 0
  else
    local _hi='\[\033[0;36m\]'  # cyan   — user, host
    local _lo='\[\033[0;31m\]'  # red    — @, git, $
    local _di='\[\033[0;33m\]'  # yellow — dir
    local _ok='\[\033[0;32m\]'  # green  — exit 0
  fi
  local git_branch=""
  if command -v __git_ps1 &>/dev/null; then
    git_branch="$(__git_ps1 "${_lo}(%s)${_nc}")"
  fi
  if [ $last_status -eq 0 ]; then
    export PS1="${_hi}\u${_lo}@${_hi}\h${_nc}[${_di}\W${_nc}]${git_branch}:${_ok}${last_status}${_nc}:${_lo}\\$ ${_nc}"
  else
    export PS1="${_hi}\u${_lo}@${_hi}\h${_nc}[${_di}\w${_nc}]${git_branch}:${_lo}${_bold}${last_status}${_nc}:${_lo}\\$ ${_nc}"
  fi
}

# history settings for multipe terminals
# see https://unix.stackexchange.com/questions/1288/preserve-bash-history-in-multiple-terminal-windows
export HISTSIZE=20000
export HISTFILESIZE=50000
export HISTCONTROL=ignoredups:erasedups
export HISTIGNORE="&:ls:bg:fg:exit:history"
export HISTTIMEFORMAT='%Y-%m-%d %H:%M.%S | '
shopt -s histappend
unset PROMPT_COMMAND

# synch bash history
_bash_history_sync() {
  builtin history -a
  HISTFILESIZE=$HISTSIZE
  builtin history -c
  builtin history -r
}

# used for logic prior to prompt generation
_render_prompt() {
  _generate_ps1
  _bash_history_sync
}

# this value is executed as a command prior to issuing each primary prompt 
# so make sure all stuff that needs to be done
export PROMPT_COMMAND=_render_prompt

# override original history to sync
history() {
  _bash_history_sync
  builtin history "$@"
}


# color options for utils
export LS_OPTIONS='--color=auto'
# theme-aware ls colors: light mode sets fi=0;30 so regular filenames are dark, not grey
# note: permissions/owner/date columns are plain terminal text — set PuTTY Default Foreground
# to black (Window > Colours) for those to appear dark on a white background
if [[ "$(cat ~/.theme-bash-tmux-vim 2>/dev/null)" == "light" ]]; then
  export LS_COLORS='rs=0:fi=0;30:di=01;34:ln=01;36:pi=01;33:so=01;35:bd=01;33:cd=01;33:or=01;31:ex=01;32'
else
  unset LS_COLORS
fi
#eval "`dircolors`"
alias egrep='egrep --color=auto'
alias fgrep='fgrep --color=auto'
alias grep='grep --color=auto'
alias ls='ls --color=auto'
# colors for less, useful in manpages
export LESS_TERMCAP_mb=$(printf '\e[01;31m') # enter blinking mode - red
export LESS_TERMCAP_md=$(printf '\e[01;33m') # enter double-bright mode - bold, magenta
export LESS_TERMCAP_me=$(printf '\e[0m') # turn off all appearance modes (mb, md, so, us)
export LESS_TERMCAP_se=$(printf '\e[0m') # leave standout mode
export LESS_TERMCAP_so=$(printf '\e[01;35m') # enter standout mode - yellow
export LESS_TERMCAP_ue=$(printf '\e[0m') # leave underline mode
export LESS_TERMCAP_us=$(printf '\e[04;36m') # enter underline mode - cyan

# aliases
alias ll='ls -lh --color=auto'
alias la='ls -lah --color=auto'
alias myip='curl icanhazip.com/s'


# GPG agent for SSH authentication (Linux)
# https://ryanlue.com/posts/2017-06-29-gpg-for-ssh-auth
if command -v gpgconf &>/dev/null; then
  export "GPG_TTY=$(tty)"
  export SSH_AUTH_SOCK="$(gpgconf --list-dirs agent-ssh-socket)"
  gpgconf --launch gpg-agent
fi

# man pages in vim ヽ(´▽`)/
function vman {
  if ! command -v vim &>/dev/null; then echo "vim not installed"; return 1; fi
  man "$@" | vim -MR -c 'file [stdin]' +"set filetype=man" -
}

# set up /etc/motd for this host
function vsetupmotd {
  if [[ ! -x "$HOME/bin/setup-motd" ]]; then echo "setup-motd not found in ~/bin"; return 1; fi
  bash "$HOME/bin/setup-motd"
}

