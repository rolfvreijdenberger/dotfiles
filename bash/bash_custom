# install preferred packages on a new machine
# supports debian, ubuntu, rhel, fedora, centos
function vinstall {
  # detect package manager
  if command -v apt &>/dev/null; then
    PM="apt"
    PM_INSTALL="sudo apt install --assume-yes"
    PM_UPDATE="sudo apt update"
    PKG_VIM="vim-nox"
    PKG_NETCAT="netcat-openbsd"
    PKG_DNS="dnsutils"
    PKG_MTR="mtr-tiny"
    PKG_7ZIP="p7zip-full"
    PKG_FIREWALL="ufw"
  elif command -v dnf &>/dev/null || command -v yum &>/dev/null; then
    PM=$(command -v dnf &>/dev/null && echo dnf || echo yum)
    PM_INSTALL="sudo $PM install --assumeyes"
    PM_UPDATE="sudo $PM check-update; true"  # check-update returns 100 when updates exist, not an error
    PKG_VIM="vim-enhanced"
    PKG_NETCAT="nmap-ncat"
    PKG_DNS="bind-utils"
    PKG_MTR="mtr"
    PKG_7ZIP="p7zip"
    PKG_FIREWALL="firewalld"
  else
    echo "no supported package manager found (apt-get, dnf, yum)"
    return 1
  fi

  echo "detected package manager: $PM"
  echo "updating package index..."
  eval "$PM_UPDATE"

  # common packages available on all distros
  PACKAGES=(
    "$PKG_VIM" tmux git
    htop iotop iftop sysstat
    curl wget rsync
    nmap tcpdump iperf3
    traceroute whois net-tools
    lsof strace
    tree ncdu
    jq fzf ripgrep
    zip unzip
    fail2ban
    bash-completion
    gnupg2
    cmatrix
    mosh
  )

  # distro-specific package names
  PACKAGES+=(
    "$PKG_NETCAT"
    "$PKG_DNS"
    "$PKG_MTR"
    "$PKG_7ZIP"
    "$PKG_FIREWALL"
  )

  # clipboard tools only on systems with a display
  if [[ -n "$DISPLAY" || -n "$WAYLAND_DISPLAY" ]]; then
    echo "display detected — installing clipboard tools"
    PACKAGES+=(xclip wl-clipboard)
  else
    echo "headless server — skipping clipboard tools"
  fi

  echo "installing packages..."
  $PM_INSTALL "${PACKAGES[@]}"
  echo "done installing packages"
}

# system status overview — useful on login or after something feels off
function vstatus {
  echo ""
  echo "  HOST"
  echo "    hostname  : $(hostname -f 2>/dev/null || hostname)"
  echo "    uptime    : $(uptime -p 2>/dev/null || uptime)"
  echo "    date      : $(date)"
  echo ""
  echo "  LOAD & MEMORY"
  echo "    load      : $(cut -d' ' -f1-3 /proc/loadavg) (1/5/15 min)"
  free -h | awk '/^Mem:/ { printf "    memory    : %s used / %s total / %s free\n", $3, $2, $4 }'
  echo ""
  echo "  DISK"
  df -h --output=target,pcent,used,size -x tmpfs -x devtmpfs 2>/dev/null | \
    awk 'NR==1 { next } { printf "    %-20s %s used of %s (%s)\n", $1, $3, $4, $2 }'
  echo ""
  echo "  NETWORK"
  ip -brief addr show 2>/dev/null | awk '{ printf "    %-10s %-12s %s\n", $1, $2, $3 }' || \
    ifconfig 2>/dev/null | grep -E 'inet |^[a-z]'
  echo ""
  echo "  LOGINS"
  echo "    last logins:"
  last -n 5 -a 2>/dev/null | head -5 | awk '{ printf "    %s\n", $0 }'
  echo ""
  echo "  SECURITY"
  if command -v fail2ban-client &>/dev/null; then
    BANNED=$(sudo -n fail2ban-client status sshd 2>/dev/null | grep 'Currently banned' | awk '{print $NF}')
    echo "    fail2ban  : ${BANNED:-needs root (sudo -n failed)} currently banned on sshd"
  else
    echo "    fail2ban  : not installed"
  fi
  local lastb_out; lastb_out=$(lastb -n 5 2>/dev/null) && \
    FAILED=$(echo "$lastb_out" | wc -l) || FAILED="needs root"
  echo "    failed ssh: ${FAILED} recent attempts (lastb)"
  echo ""
}

# switch terminal/vim/tmux between light and dark color themes
function vtheme {
  local mode="${1:-}"
  if [[ "$mode" != "light" && "$mode" != "dark" ]]; then
    echo "usage: vtheme [light|dark]  (current: $(cat ~/.theme-bash-tmux-vim 2>/dev/null || echo dark))"
    return 1
  fi
  echo "$mode" > ~/.theme-bash-tmux-vim
  [[ -n "$TMUX" ]] && { tmux source-file ~/.tmux.conf || true; }
  if [[ "$mode" == "light" ]]; then
    export LS_COLORS='rs=0:fi=0;30:di=01;34:ln=01;36:pi=01;33:so=01;35:bd=01;33:cd=01;33:or=01;31:ex=01;32'
    # COLORFGBG signals light background to tools that respect it (vim, some others)
    export COLORFGBG="0;15"
    # LESS_TERMCAP: use dark bold colors readable on white (replaces bright defaults)
    export LESS_TERMCAP_mb=$(printf '\e[01;31m')
    export LESS_TERMCAP_md=$(printf '\e[01;34m')
    export LESS_TERMCAP_so=$(printf '\e[01;35m')
    export LESS_TERMCAP_us=$(printf '\e[01;32m')
  else
    unset LS_COLORS
    export COLORFGBG="15;0"
    export LESS_TERMCAP_mb=$(printf '\e[01;31m')
    export LESS_TERMCAP_md=$(printf '\e[01;33m')
    export LESS_TERMCAP_so=$(printf '\e[01;35m')
    export LESS_TERMCAP_us=$(printf '\e[04;36m')
  fi
  # OSC (Operating System Command) sequences to change terminal background/foreground
  # supported by PuTTY, Windows Terminal (PowerShell), and Linux terminal emulators
  # inside tmux wrapped in DCS passthrough to reach the outer terminal
  if [[ "$mode" == "light" ]]; then
    if [[ -n "$TMUX" ]]; then
      printf '\ePtmux;\e\e]11;rgb:ff/ff/ff\a\e\\' || true
      printf '\ePtmux;\e\e]10;rgb:00/00/00\a\e\\' || true
    else
      printf '\e]11;rgb:ff/ff/ff\a' || true
      printf '\e]10;rgb:00/00/00\a' || true
    fi
  else
    if [[ -n "$TMUX" ]]; then
      printf '\ePtmux;\e\e]111;\a\e\\' || true
      printf '\ePtmux;\e\e]110;\a\e\\' || true
    else
      printf '\e]111;\a' || true
      printf '\e]110;\a' || true
    fi
  fi
  clear
  if [[ "$mode" == "light" ]]; then
    echo "theme: light — terminal bg: #bcbcbc or white if OSC unsupported, vim updates on focus"
  else
    echo "theme: dark  — terminal bg: reset to default if OSC unsupported, vim updates on focus"
  fi
}

# re-source bash configuration
function vbs { source ~/.bashrc; }

# use pushd internally (https://www.redhat.com/sysadmin/cd-command)
function cd
{
  if [ $# -eq 0 ]; then
    pushd ~ > /dev/null
  elif [ " $1" = " -" ]; then
    pushd "$OLDPWD" > /dev/null
  else
    pushd "$@" > /dev/null
  fi
}
