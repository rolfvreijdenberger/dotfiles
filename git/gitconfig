# ~/.gitconfig 
[user]
	name              = Rolf Vreijdenberger
	email             = rolf@vreijdenberger.nl
[push]
	default           = simple
[pull]
    rebase            = true
[rebase]
    autoStash         = true
[fetch]
    prune             = true
[init]
    defaultBranch     = main
[color]
    ui                = true
[core]
    editor            = vim
    pager             = less -R
    autocrlf          = input
[merge]
    tool              = vimdiff
[diff]
    tool              = vimdiff
[alias]
    last              = !git --no-pager log -1 HEAD
    lg                = log --oneline --graph --decorate --all
    st                = status -sb
    unstage           = reset HEAD --
    aliases           = !git config --get-regexp '^alias\\.' | sed 's/alias\\.//g'
