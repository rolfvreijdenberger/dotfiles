# ~/.gitconfig 
[user]
	name              = Rolf Vreijdenberger
	email             = rolf@vreijdenberger.nl
[push]
	default           = simple
[pull]
    rebase            = true
[rebase]
    autoStash         = true
[fetch]
    prune             = true
[init]
    defaultBranch     = main
[color]
    ui                = true
[color "decorate"]
    head              = bold magenta
    branch            = bold blue
    remoteBranch      = bold red
    tag               = bold green
    stash             = bold cyan
[color "log"]
    commit            = bold blue
[color "branch"]
    current           = bold green
    local             = bold blue
    remote            = bold red
[color "status"]
    added             = bold green
    changed           = bold red
    untracked         = bold blue
    branch            = bold magenta
[color "diff"]
    meta              = bold blue
    frag              = bold magenta
    old               = bold red
    new               = bold green
[core]
    editor            = vim
    pager             = less -R
    autocrlf          = input
[merge]
    tool              = vimdiff
[diff]
    tool              = vimdiff
[alias]
    last              = !git --no-pager log -1 HEAD
    lg                = log --oneline --graph --decorate --all
    st                = status -sb
    unstage           = reset HEAD --
    aliases           = !git config --get-regexp '^alias\\.' | sed 's/alias\\.//g'
